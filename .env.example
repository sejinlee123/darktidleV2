# Neon Postgres (used by Prisma). Same value Prisma reads via prisma.config.ts (dotenv loads .env).
#
# pg driver warning about sslmode: if your host uses sslmode=require (or prefer / verify-ca),
# append an explicit mode so future pg v9 matches today’s behavior:
#   ?sslmode=verify-full          (first query param)
#   &sslmode=verify-full          (if the URL already has ?…)
# Local Postgres without TLS: omit sslmode or use a non-SSL URL as you do today.
DATABASE_URL=

# Better Auth — min 32 chars, high entropy (e.g. openssl rand -base64 32)
BETTER_AUTH_SECRET=

# App origin for auth callbacks and links (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000
